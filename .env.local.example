# このファイルを .env.local にコピーして値を入れてください。
# .env.local は .gitignore 済みなので外部に漏れません。

# 1) https://www.notion.so/my-integrations で「新しいインテグレーション」を作成し、
#    表示される "Internal Integration Secret"(secret_ または ntn_ で始まる文字列)を貼る
NOTION_TOKEN=

# 2) 買い物リストのデータベースを開き、URL の中の 32文字の英数字がデータベースID
#    例: https://www.notion.so/xxxx/<ここの32文字>?v=...
#    ※ハイフンあり・なしどちらでもOK
NOTION_DATABASE_ID=

# 3) 対象のデータベースページ右上「…」→「接続」→ 作ったインテグレーションを追加するのを忘れずに！

# 4) 公開時のアクセス保護(任意)。設定するとサイト全体に Basic 認証がかかる。
#    ローカル開発では空のままでOK(認証なし)。Vercel 等の公開環境では必ず設定推奨。
#    ブラウザのログイン画面では、ユーザー名は任意・パスワードにこの値を入力する。
APP_PASSWORD=
